# Supabase
SUPABASE_URL=https://XXXXXXXXXX.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXXXX

# Resend (emails transaccionales)
RESEND_API_KEY=re_XXXXXXXXXX

# Admin (formato: usuario:contraseña|usuario2:contraseña2)
ADMIN_USERS=usuario1:contraseña1|usuario2:contraseña2

# Google Calendar (Service Account)
# El archivo server/google-service-account.json debe existir en el servidor (NO subir al repo)
GOOGLE_CALENDAR_ID=tu_correo@gmail.com

# URLs
VITE_API_URL=                    # vacío en producción (Express sirve el frontend)
FRONTEND_URL=https://technecreativ.com
NODE_ENV=production

# NO configurar PORT — Hostinger lo inyecta automáticamente
