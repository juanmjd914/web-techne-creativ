{
  "name": "web-techne-creativ",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node --env-file=.env --experimental-strip-types server/index.ts\"",
    "build": "npm install --include=dev && tsc -p tsconfig.app.json --noEmit --skipLibCheck && tsc -p tsconfig.server.json && vite build",
    "preview": "vite preview",
    "start": "node server-dist/index.js",
    "build:server": "tsc -p tsconfig.server.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.0",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^173.0.0",
    "lucide-react": "^0.400.0",
    "motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.0.0",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.2",
    "vite": "^6.0.0"
  }
}
